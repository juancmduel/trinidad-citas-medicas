@startuml
title "Diagrama de Despliegue\nTopología de Hardware - Clínica Trinidad & Especialidades Médicas"

skinparam backgroundColor #FEFEFE
skinparam node {
  BorderColor #1B4F72
  BackgroundColor #D6EAF8
  FontSize 12
}
skinparam artifact {
  BorderColor #6C3483
  BackgroundColor #E8DAEF
  FontSize 10
}
skinparam component {
  BorderColor #117A65
  BackgroundColor #D5F5E3
}

' ── NODO 1: CLIENTE ──
node "Nodo Cliente\n«Workstations Clínica»" as Cliente {
  artifact "Navegador Web\n(Chrome / Edge)" as browser
  component "Interfaz de Usuario\n(Frontend React.js)" as frontend
  browser -d- frontend
  artifact "Sistema Operativo\nWindows 10/11 Pro" as soCli
}

' ── RED LAN ──
node "Red LAN / WAN\nGigabit Ethernet" as Red

' ── NODO 2: SERVIDOR WEB ──
node "Nodo Servidor Web/Aplicaciones\n«Data Center Clínica»" as Servidor {
  artifact "Sistema Operativo\nUbuntu Server 22.04 LTS" as soSrv
  artifact "Apache Tomcat 9\n(Servlet Container)" as tomcat
  artifact "clinica-api.war\n(Backend Spring Boot)" as war {
    component "Controladores REST" as rest
    component "Servicios\nde Negocio" as services
    component "DAO\n(Data Access Objects)" as daos
  }
  artifact "auth-service.jar\n(JWT + BCrypt)" as auth
  artifact "report-engine.jar\n(Generador Reportes)" as reports
  artifact "notifier-service.jar\n(SMS / Email)" as notifier
}

' ── NODO 3: BASE DE DATOS ──
node "Nodo Servidor de Base de Datos\n«Alta Disponibilidad»" as BD {
  artifact "Sistema Operativo\nWindows Server 2022" as soBD
  artifact "SQL Server 2022\n(Enterprise Edition)" as sqlserver {
    artifact "Base de Datos\nClinicaTrinidad" as database
  }
  artifact "SQL Server Agent\n(Jobs / Backup)" as agent
}

' ── CONEXIONES ──
Cliente -u- Red : "HTTP/HTTPS"
Red -d- Servidor : "HTTP/HTTPS (Puerto 443/80)"
Servidor -u- Red : "JDBC/SSL (Puerto 1433)"
Red -d- BD : "TCP/IP"

' ── NOTAS ADICIONALES ──
note top of Cliente : 5 workstations:\nRecepción (3)\nConsultorios (2)
note top of BD : Cluster de conmutación\nerror (Always On)

@enduml