@startuml
allowmixing
skinparam backgroundColor #FEFEFE
skinparam packageBorderColor #2E86C1
skinparam packageBackgroundColor #EBF5FB
skinparam nodeBorderColor #117A65
skinparam nodeBackgroundColor #D5F5E3

title "Capa de Acceso a Datos (Persistencia)\nPatrón DAO - Data Access Object"

package "Capa de Negocio\n(Business Layer)" as Business {
  interface "Servicio Usuario" as SvcUser
  interface "Servicio Cita" as SvcCita
  interface "Servicio Paciente" as SvcPac
  interface "Servicio Pago" as SvcPago
}

package "Capa de Acceso a Datos\n(DAO Pattern)" as DAO {
  package "DAO Interfaces" as DAOInterfaces {
    interface "IUsuarioDAO" as IUserDAO
    interface "ICitaDAO" as ICitaDAO
    interface "IPacienteDAO" as IPacDAO
    interface "IPagoDAO" as IPagoDAO
    interface "IHistoriaDAO" as IHistDAO
    interface "IAuditoriaDAO" as IAudDAO
  }

  package "Implementaciones DAO" as DAOImpl {
    class "UsuarioDAOImpl" as UserDAOImpl
    class "CitaDAOImpl" as CitaDAOImpl
    class "PacienteDAOImpl" as PacDAOImpl
    class "PagoDAOImpl" as PagoDAOImpl
    class "HistoriaDAOImpl" as HistDAOImpl
    class "AuditoriaDAOImpl" as AudDAOImpl
    class "ReporteDAOImpl" as RepDAOImpl
    class "EspacioDAOImpl" as EspDAOImpl
  }

  package "Entidades del Modelo" as Entities {
    class Usuario {
      +idUsuario: int
      +tipoDocumento: string
      +numeroDocumento: string
      +nombres: string
      +apellidos: string
      +correo: string
      +telefono: string
      +rolID: int
    }
    class Cita {
      +idCita: int
      +idPaciente: int
      +idMedico: int
      +fechaHora: DateTime
      +estado: string
      +motivo: string
    }
    class Paciente {
      +idPaciente: int
      +tipoDoc: string
      +dni: string
      +nombres: string
      +apellidos: string
      +fechaNac: Date
      +telefono: string
      +correo: string
      +direccion: string
    }
    class Pago {
      +idPago: int
      +idReserva: int
      +monto: decimal
      +impuesto: decimal
      +descuento: decimal
      +formaPago: string
      +fechaPago: DateTime
      +referencia: string
    }
    class HistoriaClinica {
      +idHistoria: int
      +idPaciente: int
      +idMedico: int
      +motivoConsulta: string
      +enfermedadActual: string
      +examenFisico: string
      +diagnosticoCIE10: string
      +planTratamiento: string
      +fecha: DateTime
    }
    class Auditoria {
      +idAuditoria: int
      +idUsuario: int
      +accion: string
      +modulo: string
      +detalle: string
      +fechaHora: DateTime
      +direccionIP: string
      +dispositivo: string
    }
  }
}

node "SQL Server 2022" as DB {
  artifact "Tabla: Usuarios" as T1
  artifact "Tabla: Citas" as T2
  artifact "Tabla: Pacientes" as T3
  artifact "Tabla: Pagos" as T4
  artifact "Tabla: HistoriaClinica" as T5
  artifact "Tabla: Auditoria" as T6
  artifact "Tabla: Espacios" as T7
  artifact "Tabla: Precios" as T8
}

' Conexiones entre capas
SvcUser --> IUserDAO : «usa»
SvcCita --> ICitaDAO : «usa»
SvcPac --> IPacDAO : «usa»
SvcPago --> IPagoDAO : «usa»

' Implementaciones de Interfaces
IUserDAO <|.. UserDAOImpl
ICitaDAO <|.. CitaDAOImpl
IPacDAO <|.. PacDAOImpl
IPagoDAO <|.. PagoDAOImpl
IHistDAO <|.. HistDAOImpl
IAudDAO <|.. AudDAOImpl

' DAOImpl manipula Entidades
UserDAOImpl --> Usuario : CRUD
CitaDAOImpl --> Cita : CRUD
PacDAOImpl --> Paciente : CRUD
PagoDAOImpl --> Pago : CRUD
HistDAOImpl --> HistoriaClinica : CRUD
AudDAOImpl --> Auditoria : CRUD

' DAOImpl se conecta a BD
UserDAOImpl --> DB : Microsoft JDBC
CitaDAOImpl --> DB : Microsoft JDBC
PacDAOImpl --> DB : Microsoft JDBC
PagoDAOImpl --> DB : Microsoft JDBC
HistDAOImpl --> DB : Microsoft JDBC
AudDAOImpl --> DB : Microsoft JDBC
RepDAOImpl --> DB : Microsoft JDBC
EspDAOImpl --> DB : Microsoft JDBC

@enduml