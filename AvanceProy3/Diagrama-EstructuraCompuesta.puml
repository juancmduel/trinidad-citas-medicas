@startuml
title "Diagrama de Estructura Compuesta\nComponente: GestorClinico"
skinparam backgroundColor #FEFEFE
skinparam component {
  FontSize 11
  BorderColor #2E86C1
  BackgroundColor #EBF5FB
}
skinparam interface {
  BorderColor #117A65
  BackgroundColor #D5F5E3
}

' ── INTERFACES GLOBALES ──
interface "IHttpRequest" as httpIn
interface "IJDBC" as jdbcOut

' ── COMPONENTE PRINCIPAL ──
component "GestorClinico" as gestor {
  port "api:APIREST" as portApi
  port "db:RepositorioBD" as portDb

  component "JwtAuth" as auth {
    port "in" as authIn
    port "out" as authOut
  }

  component "MotorAgendamiento" as agenda
  component "ProcesadorHistorias\nClinicas" as hce
  component "GestorPagos" as pagos
  component "ModuloAuditoria" as audit
  component "GeneradorReportes" as reportes
}

' ── CONEXIONES EXTERNAS ──
httpIn -- portApi
portDb -- jdbcOut

' ── CONEXIONES INTERNAS ──
portApi -- authIn : peticiones HTTP
authOut -- agenda : tokens válidos
authOut -- hce : tokens válidos
authOut -- pagos : tokens válidos
authOut -- audit : tokens válidos
authOut -- reportes : tokens válidos

agenda -- portDb : CRUD Citas
hce -- portDb : CRUD HCE
pagos -- portDb : CRUD Pagos
audit -- portDb : INSERT Logs
reportes -- portDb : SELECT

' ── NOTAS ──
note left of httpIn : <<provided interface>>\nPuerto de entrada\n(Peticiones REST)
note right of jdbcOut : <<required interface>>\nPuerto de salida\n(Conexión SQL Server)

note top of auth : Capa de Seguridad\n(JWT + BCrypt)
note top of agenda : Lógica de\nAgendamiento
note top of hce : Lógica de\nHistorias Clínicas
note top of pagos : Lógica de\nPagos y Facturación
note top of audit : Registro de\nTrazabilidad
note top of reportes : Generación de\nReportes

@enduml