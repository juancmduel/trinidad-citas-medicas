# ================================================================
#  VARIABLES DE ENTORNO — Trinidad Citas Medicas
#  Copiar este archivo a .env y completar los valores reales.
#  NUNCA committear el archivo .env con credenciales reales.
# ================================================================

# ── Base de Datos SQL Server ─────────────────────────────────────
DB_PASSWORD=tu_contraseña_sql_server_aqui

# ── JWT ──────────────────────────────────────────────────────────
# IMPORTANTE: Debe tener al menos 32 caracteres (256 bits) para HMAC-SHA256.
# Generar con: openssl rand -base64 32
JWT_SECRET=poner_aqui_un_secreto_de_al_menos_32_caracteres

# ── Correo SMTP (Gmail) ──────────────────────────────────────────
# Usar una contraseña de aplicación de Google, NO la contraseña regular.
MAIL_USERNAME=tucorreo@gmail.com
MAIL_PASSWORD=tu_contraseña_de_aplicacion

# ── Seed Data ────────────────────────────────────────────────────
# Contraseña para usuarios semilla (admin, gerente, etc.)
# Si no se define, usa 'Trinidad2026' SOLO para desarrollo local.
TRINIDAD_SEED_USER_PASSWORD=Trinidad2026

# ── CORS (Producción) ────────────────────────────────────────────
# Orígenes permitidos separados por coma. Vacío = mismo origen.
# Ej: https://miapp.com,https://admin.miapp.com
CORS_ALLOWED_ORIGINS=
